# === Model endpoint ===
# Endpoint root (no trailing /v1)
BASE_URL=http://localhost:11434
API_KEY=
MODEL_NAME=qwen3.5:0.8b

# LLM protocol adapter:
# - completions / openai_compat : POST {BASE_URL}/v1/completions
# - ollama_chat / ollama        : POST {BASE_URL}/api/chat
#
# Recommended default:
#   If you run Ollama locally, prefer "completions" and talk to Ollama's OpenAI-compat endpoint.
#   Set "ollama_chat" only if you explicitly want /api/chat.
LLM_ADAPTER=completions

# Option B: Remote OpenAI-compatible gateway
# BASE_URL=https://cpa.oldbird.cn
# API_KEY=sk-your-key
# MODEL_NAME=gpt-5.2
# LLM_ADAPTER=completions

# Request behavior
HTTP_TIMEOUT_SECONDS=20
