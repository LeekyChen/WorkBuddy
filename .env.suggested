# Choose ONE endpoint block below by uncommenting it.
# Notes:
# - BASE_URL is the server root (NO trailing /v1)
# - LLM_ADAPTER selects the protocol:
#     completions  -> POST {BASE_URL}/v1/completions (OpenAI-compatible)
#     ollama_chat  -> POST {BASE_URL}/api/chat      (Ollama native)

# === Option A: Local Ollama ===
BASE_URL=http://localhost:11434
MODEL_NAME=qwen3.5:0.8b
API_KEY=
LLM_ADAPTER=ollama_chat

# If your Ollama has OpenAI-compat /v1/completions enabled and you prefer it:
# LLM_ADAPTER=completions

HTTP_TIMEOUT_SECONDS=20

# === Option B: Remote OpenAI-compatible gateway (completions) ===
# BASE_URL=https://cpa.oldbird.cn
# MODEL_NAME=gpt-5.2
# API_KEY=sk-my-secret-key-2026
# LLM_ADAPTER=completions
# HTTP_TIMEOUT_SECONDS=20
